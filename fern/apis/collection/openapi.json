    "/v1/initiate-payment": {
      "post": {
        "tags": [
          "Pagos"
        ],
        "summary": "POST /initiate-payment",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "order_id",
                    "transaction_id",
                    "total_amount",
                    "currency",
                    "requires_otp",
                    "message"
                  ],
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "currency": {
                      "type": "string"
                    },
                    "order_id": {
                      "type": "string"
                    },
                    "requires_otp": {
                      "type": "boolean"
                    },
                    "total_amount": {
                      "type": "number"
                    },
                    "transaction_id": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "approved",
                  "message": "Payment initiated. OTP sent to customer.",
                  "currency": "USD",
                  "order_id": "ord_9981",
                  "requires_otp": true,
                  "total_amount": 1799.97,
                  "transaction_id": "txn_abc123"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "code",
                    "message"
                  ],
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "code": 400,
                  "status": "error",
                  "message": "Missing required field: total_amount."
                }
              }
            },
            "description": "Bad Request"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "error_code",
                    "message"
                  ],
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "error_code": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "rejected",
                  "message": "The transaction was declined: insufficient funds.",
                  "error_code": "INSUFFICIENT_FUNDS"
                }
              }
            },
            "description": "Payment Required"
          }
        },
        "description": "**ES:** Inicia un nuevo proceso de pago enviando los datos de la transacción. Devuelve una confirmación con el resultado del pago, indicando si fue aprobado o rechazado.\n\n**EN:** Initiates a new payment process by submitting transaction data. Returns a confirmation with the payment result, indicating whether it was approved or rejected.",
        "operationId": "postV1Initiate-payment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "items",
                  "total_amount",
                  "currency",
                  "payment_method",
                  "card_last4"
                ],
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "product_id",
                        "quantity",
                        "unit_price"
                      ],
                      "properties": {
                        "quantity": {
                          "type": "integer"
                        },
                        "product_id": {
                          "type": "string"
                        },
                        "unit_price": {
                          "type": "number"
                        }
                      }
                    }
                  },
                  "currency": {
                    "type": "string"
                  },
                  "card_last4": {
                    "type": "string"
                  },
                  "customer_id": {
                    "type": "string"
                  },
                  "total_amount": {
                    "type": "number"
                  },
                  "payment_method": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "items": [
                  {
                    "quantity": 1,
                    "product_id": "prod_001",
                    "unit_price": 1299.99
                  },
                  {
                    "quantity": 2,
                    "product_id": "prod_002",
                    "unit_price": 249.99
                  }
                ],
                "currency": "USD",
                "card_last4": "4242",
                "customer_id": "{{customer_id}}",
                "total_amount": 1799.97,
                "payment_method": "credit_card"
              }
            }
          }
        },
        "x-fern-sdk-group-name": [
          "Pagos"
        ],
        "x-fern-sdk-method-name": "POST /initiate-payment"
      }
    },
    "/v1/validate-transaction": {
      "post": {
        "tags": [
          "Validaciones"
        ],
        "summary": "POST /validate-transaction",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "order_id",
                    "transaction_id",
                    "message"
                  ],
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "order_id": {
                      "type": "string"
                    },
                    "transaction_id": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "confirmed",
                  "message": "Transaction validated successfully.",
                  "order_id": "ord_9981",
                  "transaction_id": "txn_abc123"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "code",
                    "message"
                  ],
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "code": 400,
                  "status": "error",
                  "message": "Invalid or expired OTP code."
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "description": "**ES:** Valida los datos de una transacción antes de procesarla. Verifica que los campos requeridos, montos y reglas de negocio sean correctos, evitando errores en etapas posteriores del flujo de pago.\n\n**EN:** Validates transaction data before it is processed. Checks that required fields, amounts, and business rules are correct, preventing errors in later stages of the payment flow.",
        "operationId": "postV1Validate-transaction",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "order_id",
                  "otp_code"
                ],
                "properties": {
                  "order_id": {
                    "type": "string"
                  },
                  "otp_code": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "order_id": "{{order_id}}",
                "otp_code": "847291"
              }
            }
          }
        },
        "x-fern-sdk-group-name": [
          "Validaciones"
        ],
        "x-fern-sdk-method-name": "POST /validate-transaction"
      }
    },
